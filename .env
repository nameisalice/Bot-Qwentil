# ============================================================
# KONFIGURASI BOT QWEN CLOUD (qwen1.py)
# ============================================================

# Config lama (GoMail - tidak dipakai lagi)
IMAP_HOST=mail.gopretstudio.com

# Password untuk akun yang akan didaftarkan (8-20 karakter)
PASSWORD=Astral11*

# Jumlah akun per satu batch sebelum cooldown
# (JANGAN ubah lebih dari 2, atau IP akan terkena penalti Alibaba!)
ACCOUNTS_PER_RUN=2

# Jalankan browser tersembunyi? (true = headless, false = tampilkan browser)
HEADLESS=true

# Jumlah thread berjalan bersamaan (concurrency)
CONCURRENCY=2

# Jeda antar batch dalam satu run (detik)
COOLDOWN_BETWEEN_BATCHES=30

# Jeda setelah satu run selesai sebelum restart otomatis (detik)
# Set 0 untuk menonaktifkan auto-restart
RESTART_DELAY=15

# Berapa kali bot akan auto-restart? (0 = tidak terbatas / loop selamanya)
MAX_RESTARTS=0
